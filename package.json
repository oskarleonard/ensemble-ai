{
  "name": "ensemble-ai",
  "version": "0.1.0",
  "description": "Cross-vendor AI CLI — convene multiple models on a task, read-only, and collect typed findings. Modes: review (first), brainstorm, security.",
  "license": "MIT",
  "author": "oskarleonard",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/oskarleonard/ensemble-ai.git"
  },
  "type": "module",
  "bin": {
    "ensemble-ai": "dist/cli.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./cli": {
      "types": "./dist/cli.d.ts",
      "default": "./dist/cli.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "test": "vitest run",
    "test:watch": "vitest",
    "check": "npm run typecheck && npm run lint && npm run test && npm run build"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@types/node": "^20.0.0",
    "eslint": "^9.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.0.0",
    "typescript-eslint": "^8.0.0",
    "vitest": "^4.0.0"
  }
}
